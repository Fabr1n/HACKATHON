# ===== ENVIRONMENT CONFIGURATION =====
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=seu-chave-secreta-muito-segura-coloque-no-production

# ===== SERVER CONFIGURATION =====
HOST=0.0.0.0
PORT=5000
FRONTEND_URL=http://localhost:3000

# ===== DATABASE CONFIGURATION =====
# PostgreSQL recomendado para produção
DATABASE_URL=postgresql://user:password@localhost:5432/meg_database
# Para desenvolvimento sem banco de dados (comentado = usa in-memory)

# ===== EMAIL CONFIGURATION (SMTP) =====
# OPÇÃO 1: Gmail (RECOMENDADO PARA DESENVOLVIMENTO)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
USE_TLS=True
SENDER_EMAIL=seu-email@gmail.com
SENDER_PASSWORD=seu-app-password-aqui
# Para usar Gmail:
# 1. Acesse: https://myaccount.google.com/apppasswords
# 2. Selecione "Mail" e "Windows/Linux"
# 3. Copie a senha de 16 caracteres para SENDER_PASSWORD

# OPÇÃO 2: Outlook (descomente para usar)
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587
# SENDER_EMAIL=seu-email@outlook.com
# SENDER_PASSWORD=sua-senha-outlook

# OPÇÃO 3: SendGrid (descomente para usar)
# SENDGRID_API_KEY=sua-chave-sendgrid-aqui

# EMAIL TEMPLATES
EMAIL_FROM_NAME=MEG - Mulheres Empreendedoras Goianas
EMAIL_REPLY_TO=contato@meggoianas.com.br

# ===== JWT & SESSION CONFIGURATION =====
JWT_SECRET_KEY=sua-chave-jwt-muito-segura-32-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SESSION_TIMEOUT_HOURS=7

# ===== PASSWORD & TOKEN EXPIRATION =====
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1
EMAIL_CONFIRMATION_TOKEN_EXPIRATION_HOURS=24
MENTOR_CONFIRMATION_TOKEN_EXPIRATION_DAYS=7

# ===== VIDEO CONFERENCING CONFIGURATION =====
# OPÇÃO 1: Jitsi Meet (GRATUITO - RECOMENDADO)
VIDEO_PROVIDER=jitsi
JITSI_SERVER=https://meet.jit.si
# Não precisa de credenciais para Jitsi público

# OPÇÃO 2: Agora.io (PAGO)
# VIDEO_PROVIDER=agora
# AGORA_APP_ID=sua-app-id-aqui
# AGORA_APP_CERTIFICATE=seu-certificado-aqui

# OPÇÃO 3: Twilio (PAGO)
# VIDEO_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=seu-account-sid
# TWILIO_AUTH_TOKEN=seu-auth-token
# TWILIO_VIDEO_API_KEY=sua-api-key

# ===== AWS S3 CONFIGURATION (Para uploads) =====
AWS_ACCESS_KEY_ID=sua-access-key-id
AWS_SECRET_ACCESS_KEY=sua-secret-access-key
AWS_S3_BUCKET=meg-uploads
AWS_REGION=us-east-1

# ===== STRIPE CONFIGURATION (Pagamentos) =====
STRIPE_PUBLISHABLE_KEY=pk_test_sua-chave-publica
STRIPE_SECRET_KEY=sk_test_sua-chave-secreta

# ===== TWILIO SMS CONFIGURATION (Notificações) =====
TWILIO_ACCOUNT_SID=sua-account-sid
TWILIO_AUTH_TOKEN=seu-auth-token
TWILIO_PHONE_NUMBER=+5562991234567

# ===== RATE LIMITING =====
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=meg_app.log

# ===== REDIS CACHE (Para production) =====
# REDIS_URL=redis://localhost:6379/0
# CACHE_ENABLED=False

# ===== CORS & SECURITY =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
BCRYPT_LOG_ROUNDS=12
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT_MINUTES=15

# ===== ANALYTICS & MONITORING =====
GOOGLE_ANALYTICS_ID=seu-ga-id-aqui
SENTRY_DSN=seu-sentry-dsn-aqui

# ===== FEATURE FLAGS =====
ENABLE_VIDEO_CALLS=True
ENABLE_MENTORSHIP=True
ENABLE_B2B_MATCHING=True
ENABLE_CREDIT_APPLICATIONS=True
ENABLE_PREMIUM_FEATURES=False
